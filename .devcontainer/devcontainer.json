{
    "name": "anibridge-trakt-provider",
    "image": "mcr.microsoft.com/devcontainers/base:resolute",
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers-extra/features/uv:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "astral-sh.ty",
                "charliermarsh.ruff",
                "esbenp.prettier-vscode",
                "ms-python.python",
                "SmallMain.vscode-unify-chat-provider",
                "tamasfe.even-better-toml",
                "yzhang.markdown-all-in-one"
            ],
            "settings": {
                "python-envs.terminal.autoActivationType": "shellStartup"
            }
        }
    },
    "postCreateCommand": "uv sync --all-extras --all-groups --all-packages",
    "containerEnv": {
        "UV_LINK_MODE": "copy"
    },
    "mounts": ["source=gh-auth,target=/home/vscode/.config/gh,type=volume"]
}
